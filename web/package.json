{
  "name": "throughline-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Throughline — hyperresponsive mastery UI (Nerdy). Node/Express server + React client.",
  "scripts": {
    "dev": "concurrently -k -n client,server -c cyan,magenta \"vite\" \"tsx watch server/server.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^4.19.2",
    "openai": "^4.67.3",
    "multer": "^1.4.5-lts.1",
    "tsx": "^4.19.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  },
  "engines": { "node": ">=20" }
}
