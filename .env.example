# Copy to ../.env (repo root) or web/.env and fill in. The real .env is gitignored.
# This key powers the DEPLOYED app at runtime. Rotate it after a demo.
OPENAI_API_KEY=sk-...

# Optional model overrides (sensible defaults are baked into the server)
OPENAI_TUTOR_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_STT_MODEL=whisper-1
PORT=8080
